{
  "name": "lyrd-monorepo",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "build": "pnpm -r --filter './packages/*' build",
    "dev": "pnpm --parallel --filter './packages/*' --filter @lyrd/storybook dev",
    "dev:docs": "pnpm --filter @lyrd/docs dev",
    "dev:storybook": "pnpm --filter @lyrd/storybook dev",
    "build:docs": "pnpm --filter @lyrd/docs build",
    "build:storybook": "pnpm --filter @lyrd/storybook build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r --if-present test",
    "test:package": "pnpm --filter @lyrd/cli test:package",
    "test:coverage": "pnpm -r --if-present test:coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish",
    "release:status": "changeset status",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@typescript/native": "npm:typescript@^7.0.2",
    "lefthook": "^2.1.4",
    "typescript": "npm:@typescript/typescript6@^6.0.2"
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Lyrd configuration",
  "type": "object",
  "required": ["$schema", "framework", "packageManager", "styling", "paths", "adapters"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "framework": {
      "enum": ["next-app-router", "vite-react", "unknown"]
    },
    "packageManager": {
      "enum": ["pnpm", "npm", "yarn", "bun"]
    },
    "styling": {
      "enum": ["css-modules", "tailwind-v4"]
    },
    "paths": {
      "type": "object",
      "required": ["overlay"],
      "properties": {
        "overlay": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "adapters": {
      "type": "object",
      "required": ["overlay"],
      "properties": {
        "overlay": { "const": "base-ui" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}

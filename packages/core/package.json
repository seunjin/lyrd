{
  "name": "@lyrd/core",
  "version": "0.1.0-next.2",
  "description": "Central overlay intent runtime for Lyrd",
  "homepage": "https://seunjin.github.io/lyrd/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/seunjin/lyrd.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/seunjin/lyrd/issues"
  },
  "type": "module",
  "license": "MIT",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript/native": "npm:typescript@^7.0.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.3.0",
    "typescript": "npm:@typescript/typescript6@^6.0.2",
    "vitest": "^4.1.7"
  }
}
